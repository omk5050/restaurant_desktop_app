{
  "name": "billbucks",
  "version": "1.0.0",
  "description": "BillBucks Restaurant POS Desktop App",
  "main": "main.js",
  "scripts": {
    "dev:frontend": "npm run dev --prefix appss/web",
    "dev:electron": "wait-on http://localhost:5173 && cross-env NODE_ENV=development electron .",
    "dev": "concurrently \"npm run dev:frontend\" \"npm run dev:electron\"",
    "build:frontend": "npm run build --prefix appss/web",
    "dist": "npm run build:frontend && electron-builder"
  },
  "build": {
    "appId": "com.billbucks.app",
    "productName": "BillBucks",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "main.js",
      "backend/**/*",
      "appss/web/dist/**/*"
    ],
    "win": {
      "target": "nsis",
      "icon": "backend/image.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "cloudinary": "^2.6.1",
    "cors": "^2.8.5",
    "dotenv": "^16.5.0",
    "exceljs": "^4.4.0",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.15.0",
    "multer": "^1.4.5-lts.2",
    "node-cron": "^4.6.0",
    "resend": "^6.17.2"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "electron": "^31.3.1",
    "electron-builder": "^24.13.3",
    "wait-on": "^7.2.0"
  }
}
